<Window x:Class="PomodoroTimer.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки — Pomodoro Timer"
        Height="280" Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#12122A"
        FontFamily="Segoe UI"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="DlgButton" TargetType="Button">
            <Setter Property="Background" Value="#1E1E40"/>
            <Setter Property="Foreground" Value="#C0C8D8"/>
            <Setter Property="BorderBrush" Value="#2A2A60"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2A2A68"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E94560"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1E1E40"/>
            <Setter Property="Foreground" Value="#C0C8D8"/>
            <Setter Property="BorderBrush" Value="#2A2A60"/>
            <Setter Property="Height" Value="34"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Section header -->
        <TextBlock Grid.Row="0"
                   Text="ЗВУКОВОЙ СИГНАЛ ПО ЗАВЕРШЕНИИ"
                   Foreground="#3A4A60"
                   FontSize="11" FontWeight="Bold"/>

        <!-- Sound selector row -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="CbSounds"
                      Grid.Column="0"
                      DisplayMemberPath="Name"
                      SelectionChanged="CbSounds_SelectionChanged"/>

            <Button Grid.Column="2"
                    Style="{StaticResource DlgButton}"
                    Content="▶  Тест"
                    MinWidth="80"
                    Click="BtnTest_Click"/>
        </Grid>

        <!-- Autostart checkbox -->
        <CheckBox x:Name="ChkAutostart"
                  Grid.Row="4"
                  Foreground="#8090A8"
                  FontSize="12"
                  Content="Запускать при старте Windows"
                  Margin="0,0,0,0"/>

        <!-- Hint text -->
        <TextBlock Grid.Row="5"
                   x:Name="TbHint"
                   Foreground="#3A4A60"
                   FontSize="10"
                   Margin="0,6,0,0"
                   TextWrapping="Wrap"/>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource DlgButton}"
                    Content="Отмена"
                    Margin="0,0,10,0"
                    Click="BtnCancel_Click"/>
            <Button Style="{StaticResource DlgButton}"
                    Content="ОК"
                    Foreground="#00E87A"
                    Click="BtnOk_Click"/>
        </StackPanel>
    </Grid>
</Window>
